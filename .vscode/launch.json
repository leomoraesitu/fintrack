{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "fintrack",
            "request": "launch",
            "type": "dart",
            "program": "${workspaceFolder}/lib/main.dart",
            "toolArgs": [
                "--dart-define-from-file=${workspaceFolder}/.env/firebase_dev.json"
            ]
        },
        {
            "name": "fintrack (profile mode)",
            "request": "launch",
            "type": "dart",
            "program": "${workspaceFolder}/lib/main.dart",
            "flutterMode": "profile",
            "toolArgs": [
                "--dart-define-from-file=${workspaceFolder}/.env/firebase_dev.json"
            ]
        },
        {
            "name": "fintrack (release mode)",
            "request": "launch",
            "type": "dart",
            "program": "${workspaceFolder}/lib/main.dart",
            "flutterMode": "release",
            "toolArgs": [
                "--dart-define-from-file=${workspaceFolder}/.env/firebase_dev.json"
            ]
        }
    ]
}